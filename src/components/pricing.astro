---
import { Tick } from "@/components/ui/icons";
import Link from "@/components/ui/link.astro";

const { plan } = Astro.props;
---

<div class="flex flex-col w-full border-2 border-[#D8DEE9] border-opacity-50 py-5 px-6 rounded-md">
  
  <!-- HEADER -->
  <div class="text-center">
    <h4 class="text-lg font-medium text-gray-400">
      {plan.name}
    </h4>

    <p class="mt-3 text-4xl font-bold text-black">
      {typeof plan.price === "object" ? plan.price.monthly : plan.price}
    </p>
  </div>

  <!-- FEATURES -->
  <ul class="grid mt-8 text-left gap-y-4">
    {
      plan.features?.map((item) => (
        <li class="flex items-start gap-3 text-gray-800">
          <Tick class="w-6 h-6" />
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <!-- BUTTON -->
  <div class="flex mt-8">
    <Link
      href={plan.button?.link || "/contact"}
      block
      style={plan.popular ? "primary" : "outline"}
    >
      {plan.button?.text || "Get Started"}
    </Link>
  </div>

</div>