---
import Container from "../container.astro";
import Link from "../ui/link.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  {
    title: "Servicios",
    path: "/Aws_Triada_S3.github.io/",
  },
  {
    title: "Productos",
    path: "/Aws_Triada_S3.github.io/pricing",
  },
  {
    title: "Sobre Nosotras",
    path: "/Aws_Triada_S3.github.io/about",
  },
  {
    title: "Contacto",
    path: "/Aws_Triada_S3.github.io/contact",
  },
  {
  title: "El Proyecto", 
  path: "/Aws_Triada_S3.github.io/proyecto",
  },
];
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/Aws_Triada_S3.github.io/" class="text-lg">
          <span class="font-bold text-slate-800 text-2xl tracking-tighter">TRIAD</span>
          <span class="text-indigo-600 text-2xl font-bold">.</span>
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex lg:px-3 py-2 items-center text-gray-600 hover:text-gray-900">
                  <span> {item.title}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </MenuItems>
    </Astronav>
    <div>
      <div class="hidden lg:flex items-center gap-4">
        <Link href="/Aws_Triada_S3.github.io/contact" size="md">Solicitar Info</Link>
      </div>
    </div>
  </header>
</Container>