---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import PricingCard from "@/components/ui/pricing.astro";

const pricing = [
  {
    name: "Business Audit",
    price: "Consultar",
    features: [
      "Auditoría de datos inicial",
      "Mapa de procesos operativos",
      "Identificación de ROI",
      "Reporte de recomendaciones",
    ],
    button: {
      text: "Solicitar Auditoría",
      link: "/contact",
    },
  },
  {
    name: "Digital Growth",
    price: "A medida",
    popular: true,
    features: [
      "Rediseño UX/UI",
      "Analítica avanzada",
      "Estrategia de retención",
      "Soporte estratégico",
    ],
    button: {
      text: "Hablar con Estrategia",
      link: "/contact",
    },
  },
  {
    name: "Cloud Architecture",
    price: "Consultar",
    features: [
      "Migración a AWS",
      "Automatización con Python/SQL",
      "Escalabilidad",
      "Mantenimiento técnico",
    ],
    button: {
      text: "Consultar Cloud",
      link: "/contact",
    },
  },
];
---

<Layout title="Productos | TRIAD">
  <Container>

    <div class="text-center mt-10">
      <h1 class="text-3xl font-bold text-slate-800">
        Nuestros Productos
      </h1>
      <p class="text-slate-500 mt-2">
        Soluciones adaptadas a tu negocio
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-10 mt-12">
      {
        pricing.map((plan, index) => (
          <PricingCard plan={plan} key={index} />
        ))
      }
    </div>

  </Container>
</Layout>