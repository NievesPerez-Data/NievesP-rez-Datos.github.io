---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import { Icon } from "astro-icon/components";
import Link from "@/components/ui/link.astro";

const pricing = [
  {
    name: "Business Audit",
    price: "Consultar",
    description: "Análisis profundo de KPIs y detección de cuellos de botella operativos.",
    features: [
      "Auditoría de datos inicial",
      "Mapa de procesos operativos",
      "Identificación de puntos de fuga de ROI",
      "Reporte de recomendaciones",
    ],
    button: "Solicitar Auditoría",
  },
  {
    name: "Digital Growth",
    price: "A medida",
    description: "Estrategia de diseño de producto y optimización de conversión basada en datos.",
    features: [
      "Rediseño UX/UI de embudos",
      "Implementación de analítica avanzada",
      "Estrategia de retención",
      "Soporte en toma de decisiones",
    ],
    popular: true,
    button: "Hablar con Estrategia",
  },
  {
    name: "Cloud Architecture",
    price: "Consultar",
    description: "Infraestructura robusta y automatización de datos bajo el estándar AWS.",
    features: [
      "Migración a entorno AWS Cloud",
      "Automatización con Python/SQL",
      "Seguridad y escalabilidad total",
      "Mantenimiento y eficiencia técnica",
    ],
    button: "Consultar Cloud Lead",
  },
];
---

<Layout title="Productos | TRIAD">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Nuestros Productos</Fragment>
      <Fragment slot="desc">
        Soluciones estratégicas adaptadas a la madurez tecnológica de tu negocio.
      </Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-3 gap-10 mx-auto max-w-6xl mt-12">
      {
        pricing.map((item, index) => (
          <div key={index} class={`flex flex-col p-8 rounded-2xl border ${item.popular ? 'border-indigo-500 shadow-xl scale-105' : 'border-slate-200'} bg-white text-center relative`}>
            
            {item.popular && (
              <span class="absolute top-0 right-1/2 translate-x-1/2 -translate-y-1/2 bg-indigo-600 text-white px-3 py-1 rounded-full text-xs font-bold uppercase">
                Recomendado
              </span>
            )}

            <h3 class="text-xl font-bold text-slate-800">{item.name}</h3>
            <p class="text-3xl font-bold mt-4 text-slate-900">{item.price}</p>
            <p class="mt-4 text-slate-500 text-sm">{item.description}</p>
            
            <ul class="mt-8 space-y-4 text-left flex-1">
              {item.features.map((feature, i) => (
                <li key={i} class="flex items-center gap-2 text-slate-600 text-sm">
                  <Icon name="bx:bx-check" class="w-5 h-5 text-indigo-500" />
                  {feature}
                </li>
              ))}
            </ul>
            
            <div class="mt-10">
              <Link
                href="/contact"
                style={item.popular ? "primary" : "outline"}
                block>
                {item.button}
              </Link>
            </div>

          </div>
        ))
      }
    </div>
  </Container>
</Layout>