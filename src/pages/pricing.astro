---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import PricingCard from "@/components/ui/pricing.astro"; 

const pricing = [
  {
    name: "Business Audit",
    price: "Consultar",
    popular: false,
    features: [
      "Auditoría de datos inicial",
      "Mapa de procesos operativos",
      "Identificación de ROI",
      "Reporte de recomendaciones",
    ],
    button: {
      text: "Solicitar Auditoría",
      link: "/contact",
    },
  },
  {
    name: "Digital Growth",
    price: "A medida",
    popular: true,
    features: [
      "Rediseño UX/UI",
      "Analítica avanzada",
      "Estrategia de retención",
      "Soporte estratégico",
    ],
    button: {
      text: "Hablar con Estrategia",
      link: "/contact",
    },
  },
  {
    name: "Cloud Architecture",
    price: "Consultar",
    popular: false,
    features: [
      "Migración a AWS",
      "Automatización con Python/SQL",
      "Escalabilidad",
      "Mantenimiento técnico",
    ],
    button: {
      text: "Consultar Cloud Lead",
      link: "/contact",
    },
  },
];
---

<Layout title="Productos | TRIAD">
  <Container>
    <div class="text-center mt-16">
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight text-slate-800">
        Nuestros Productos
      </h1>
      <p class="text-lg mt-4 text-slate-600 mx-auto max-w-xl">
        Soluciones estratégicas para analítica y arquitectura cloud diseñadas para escalar.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-10 mt-16 max-w-6xl mx-auto mb-20">
      {
        pricing.map((plan) => (
          <PricingCard plan={plan} />
        ))
      }
    </div>
  </Container>
</Layout>